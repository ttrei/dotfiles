#!/usr/bin/env bash
set -euo pipefail

# i3-volume-control — thin client for the saturn volume HTTP API.
default_base="http://127.0.0.1:8899"
base="${SATURN_VOLUME_BASE:-$default_base}"

usage() {
    echo "Usage: $0 [up|down|mute|set PERCENTAGE]" >&2
}

post() {
    curl -fsS --connect-timeout 1 --max-time 2 -X POST "$1" >/dev/null
}

case "${1:-}" in
    "up")
        post "$base/volume/up"
        ;;
    "down")
        post "$base/volume/down"
        ;;
    "mute")
        post "$base/volume/mute"
        ;;
    "set")
        if [ -z "${2:-}" ]; then
            usage
            exit 1
        fi
        post "$base/volume/set?v=${2}"
        ;;
    *)
        usage
        exit 1
        ;;
esac
